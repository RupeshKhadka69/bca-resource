{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": [
    "src",
    "prisma/**/*.ts",
    "generated/**/*.d.ts",
    "prisma.config.ts"
  ]
}
